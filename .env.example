# Distilled.news environment example
#
# Copy this file to `.env` for local development. Do not commit real secrets.

# Cloudflare
# API token used by Wrangler/automation to deploy Workers, D1, R2, Queues,
# and related Cloudflare resources.
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID that owns the Worker and storage resources.
CLOUDFLARE_ACCOUNT_ID=

# Optional Cloudflare zone ID for custom-domain routes such as distilled.news.
# Not required when testing on a workers.dev URL.
CLOUDFLARE_ZONE_ID=

# Cloudflare AI Gateway identifier/name used to route OpenAI requests through
# Cloudflare AI Gateway. `default` auto-creates on first authenticated request
# for third-party models.
CLOUDFLARE_AI_GATEWAY_ID=default

# Cloudflare API token with AI Gateway Run/Edit access, sent as the
# cf-aig-authorization header when your gateway requires Cloudflare auth.
# For local setup this can be the same token used by Wrangler, but a narrower
# gateway-only token is preferred for production.
CLOUDFLARE_AI_GATEWAY_TOKEN=

# OpenAI
# OpenAI API key used for relevance filtering and summarization through
# Cloudflare AI Gateway.
OPENAI_API_KEY=

# OpenAI chat model used for production summaries through AI Gateway.
OPENAI_MODEL=gpt-4.1-mini

# Apify
# Optional token used for curated live source actors. Required for `news:`,
# `x:`, `linkedin:`, and `apify:` sources.
APIFY_API_TOKEN=

# Actor IDs are configurable because Apify Store actors can change schema,
# pricing, or reliability over time.
APIFY_GOOGLE_NEWS_ACTOR_ID=groupoject/google-news-scraper
APIFY_X_ACTOR_ID=kaitoeasyapi/twitter-x-data-tweet-scraper-pay-per-result-cheapest
APIFY_LINKEDIN_COMPANY_ACTOR_ID=harvestapi/linkedin-company-posts
APIFY_LINKEDIN_PROFILE_ACTOR_ID=harvestapi/linkedin-profile-posts

# Distilled app secrets
# Secret used to sign/admin-protect the self-hosted admin surface.
ADMIN_SESSION_SECRET=

# Initial setup token used once to create the admin password in a self-hosted
# install. Generate a long random value before deploying.
ADMIN_SETUP_TOKEN=

# Required internal secret for maintenance endpoints such as retention cleanup.
INTERNAL_MAINTENANCE_SECRET=

# Email address used by Cloudflare Email Service for verification and reset
# messages. The sender domain must be onboarded for Cloudflare Email Sending.
# Public signups also require Email Sending for arbitrary recipients; Email
# Routing-only bindings can send only to verified destination addresses.
EMAIL_FROM="Distilled.news <noreply@example.com>"

# Optional Turnstile keys for public signup/reset/login abuse control.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Public URLs
# Worker/API base URL. For early testing this can be a workers.dev URL.
PUBLIC_API_BASE_URL=

# Public web/feed base URL. Can be distilled.news, a custom self-hosted domain,
# or a local development URL.
PUBLIC_WEB_BASE_URL=
